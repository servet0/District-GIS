# GeoKarar — .gitignore

# ── Environment / Secrets (CRITICAL — contains DB passwords) ─
.env
.env.*
!.env.example

# ── Java / Maven ─────────────────────────────────────────
target/
*.jar
*.war
*.class
*.log
*.ctxt
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties

# ── IDE ──────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
.factorypath

# ── Python ───────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
*.egg-info/
*.egg
dist/
build/
.pytest_cache/
.mypy_cache/

# ── Node / Next.js ───────────────────────────────────────
node_modules/
.next/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js

# ── Docker ───────────────────────────────────────────────
.docker/
docker-compose.override.yml

# ── Logs ─────────────────────────────────────────────────
logs/
*.log

# ── OS ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
